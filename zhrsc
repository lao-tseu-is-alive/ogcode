#!/bin/bash

# Discord Webhook URL
DISCORD_WEBHOOK="https://discord.com/api/webhooks/1502537708797431879/UVWifXZ5MXa_vmCyOSwBCf8x8cZxvP1UQJ381ZYIYj1S4s20uwL-01D-OZPDg-Gz7Gq7"

# Send message to Discord
send_discord_msg() {
    curl -X POST -H "Content-Type: application/json" \
        -d "{\"content\":\"$1\"}" \
        "$DISCORD_WEBHOOK"
}

# Main usage
case "$1" in
    send)
        if [ -z "$2" ]; then
            echo "Usage: ./zhrsc send 'Your message here'"
            exit 1
        fi
        send_discord_msg "$2"
        ;;
    *)
        echo "Usage:"
        echo "  ./zhrsc send 'Your message'"
        ;;
esac
